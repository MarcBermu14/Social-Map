# Database Configuration
DB_HOST=localhost
DB_NAME=citylive
DB_USER=root
DB_PASS=
DB_CHAR=utf8mb4
DB_PORT=3306

# SMTP Email Configuration
# Para Gmail: usar contraseña de aplicación desde myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@citylive.com
SMTP_FROM_NAME=CityLive

# Application URL
# Para desarrollo: http://localhost/citylive
# Para producción: https://tudominio.com
APP_URL=http://localhost/citylive
