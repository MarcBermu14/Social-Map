DB_HOST=localhost
DB_PORT=3306
DB_NAME=citylive
DB_USER=root
DB_PASS=
DB_CHAR=utf8mb4

# App root path (empty for domain root, e.g. https://app.com/)
APP_BASE_PATH=

# Session settings
SESSION_NAME=citylive_session
SESSION_SECURE_COOKIE=false

# Security: set true only while running install.php
INSTALLER_ENABLED=false
